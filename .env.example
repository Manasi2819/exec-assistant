# =============================================================
# Executive AI Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =============================================================

# ── App ───────────────────────────────────────────────────────
APP_NAME="Executive AI Assistant"
APP_ENV=development                # development | production
SECRET_KEY=change_this_to_a_long_random_secret_key_at_least_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=execai
POSTGRES_USER=execai
POSTGRES_PASSWORD=execai_dev_password
# Full async URL (used by backend inside Docker)
DATABASE_URL=postgresql+asyncpg://execai:execai_dev_password@postgres:5432/execai
# Sync URL (used by Alembic migrations)
DATABASE_URL_SYNC=postgresql://execai:execai_dev_password@localhost:5432/execai

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── FAISS Vector Index ────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss        # local path; mounted volume inside Docker

# ── LLM — Option A: OpenAI (Paid) ─────────────────────────────
# Sign up at https://platform.openai.com — pay-per-token
OPENAI_API_KEY=                      # sk-...  (leave blank to disable)

# ── LLM — Option B: Google Gemini (Free tier) ─────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=                      # AIza...  (leave blank to disable)

# NOTE: If BOTH keys are set, the system routes intelligently:
#   • Heavy synthesis (MoM, Meeting Prep, Transcript) → GPT-5 / Gemini Pro
#   • High-volume classification → GPT-4.1 / Gemini Flash
# If ONLY Google key is set → all agents use Gemini models (free, rate-limited).
# If ONLY OpenAI key is set → all agents use GPT models.

# ── Embedding Model ────────────────────────────────────────────
# Used for FAISS index. Defaults to OpenAI if key is set, else Gemini embedding.
EMBEDDING_MODEL=text-embedding-3-large    # OpenAI embedding model
# EMBEDDING_MODEL=models/text-embedding-004  # Gemini embedding model (if using free option)

# ── Gmail Integration (Phase 2) ───────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/integrations/gmail/callback
GMAIL_PUBSUB_TOPIC=                  # projects/YOUR_PROJECT/topics/gmail-push

# ── Outlook / Microsoft 365 Integration (Phase 2) ────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common           # "common" for multi-tenant, or your tenant ID
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/integrations/outlook/callback

# ── Zoom Integration (Phase 2) ────────────────────────────────
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=http://localhost:8000/api/v1/integrations/zoom/callback
ZOOM_WEBHOOK_SECRET_TOKEN=

# ── Slack Integration (Phase 2) ───────────────────────────────
SLACK_BOT_TOKEN=                     # xoxb-...
SLACK_SIGNING_SECRET=

# ── n8n ───────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=admin123

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
